p4.title | escape }}\">\n      {% endif %}\n    </a>\n    <div class=\"fitRow__content\">\n      <h2>LONG-SLEEVED POLO SHIRT</h2>\n      <ul>\n        <li>Loose fit, generous volume</li>\n        <li>Straight, extended sleeves</li>\n        <li>Sloping shoulders</li>\n        <li>60 cm chest width in size M</li>\n      </ul>\n      <a class=\"fitRow__btn\" href=\"{{ longsleeve_url }}\">DISCOVER</a>\n    </div>\n  </div>\n\n</div>\n\n<style>\n  .fitStack{\n    max-width: 1100px;\n    margin: 0 auto;\n    font-weight: 700; /* ✅ BOLD ALL TEXT IN THIS SECTION */\n  }\n\n  .fitRow{\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    align-items: center;\n    margin-bottom: 50px;\n  }\n\n  .fitRow__media{\n    background: #f3f3f3;\n    min-height: 360px;\n    overflow: hidden;\n  }\n\n  .fitRow__img{\n    width: 100%;\n    height: 100%;\n    min-height: 360px;\n    object-fit: cover;\n    transition: transform .3s ease;\n  }\n\n  .fitRow__media:hover .fitRow__img{\n    transform: scale(1.02);\n  }\n\n  .fitRow__content{\n    padding: 30px 40px;\n  }\n\n  .fitRow__content h2{\n    font-size: 26px;\n    font-weight: 700; /* ✅ keep bold */\n    letter-spacing: .4px;\n    text-transform: uppercase;\n    margin-bottom: 12px;\n  }\n\n  .fitRow__content ul{\n    margin: 0 0 20px;\n    padding-left: 18px;\n    font-size: 15px;\n    color: #6a6a6a;\n    line-height: 1.6;\n    font-weight: 700; /* ✅ bold bullets */\n  }\n\n  .fitRow__btn{\n    padding: 12px 30px;\n    background: #0e2340;\n    color: #fff;\n    text-decoration: none;\n    font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    border-radius: 3px;\n    font-size: 13px;\n  }\n\n  @media (max-width: 900px){\n    .fitRow{\n      grid-template-columns: 1fr;\n    }\n    .fitRow__media,\n    .fitRow__img{\n      min-height: 300px;\n    }\n    .fitRow__content{\n      padding: 25px 15px;\n    }\n  }\n</style>",
