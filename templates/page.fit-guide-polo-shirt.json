        "custom_liquid": "<!-- POLO ICON -->\n<div class=\"uspa-polo-icon\">\n  <img\n    src=\"https://cdn.shopify.com/s/files/1/0268/3771/2953/files/PoloShirt_ICON_Slogan-H_color_002_1.png?v=1772038005\"\n    alt=\"The Polo Shirt – An Icon Born from the Game\"\n    loading=\"lazy\"\n  >\n</div>\n\n{% assign classic_url = \"https://uspoloassn.com.au/collections/mens-essentials?filter.p.m.custom.gender=Mens&filter.p.m.custom.Product_Category=Polo+Shirts&filter.v.price.gte=&filter.v.price.lte=&sort_by=manual\" %}\n{% assign performance_url = \"https://uspoloassn.com.au/search?q=player+3&options%5Bprefix%5D=last&filter.p.m.custom.gender=Mens&filter.p.m.custom.Product_Category=Polo+Shirts&filter.v.price.gte=&filter.v.price.lte=&sort_by=relevance\" %}\n{% assign premium_url = \"https://uspoloassn.com.au/search?q=polo+shirts&options%5Bprefix%5D=last&filter.p.m.custom.gender=Mens&filter.v.price.gte=120&filter.v.price.lte=&sort_by=relevance\" %}\n{% assign longsleeve_url = \"https://uspoloassn.com.au/search?q=long+sleeve+polo+shirts&options%5Bprefix%5D=last&filter.p.m.custom.gender=Mens&filter.p.m.custom.Product_Category=Polo+Shirts&filter.v.price.gte=&filter.v.price.lte=&sort_by=relevance\" %}\n\n<div class=\"pfg-wrap\">\n  <div class=\"pfg-inner\">\n\n    <h2 class=\"pfg-heading\">STYLE GUIDE - MEN'S POLO SHIRT</h2>\n\n    <p class=\"pfg-subheading\">\n      What's the difference between a classic and a regular fit? Discover the characteristics of each cut of the iconic U.S. Polo Assn.\n      polo shirt, and choose the model that best suits your style and body type.\n    </p>\n\n    <div class=\"pfg-sectionHeadingRow\">\n      <h2 class=\"pfg-gridTitle\">OUR STYLES</h2>\n    </div>\n\n    <div class=\"pfg-grid\">\n\n      <!-- 1 -->\n      <a class=\"pfg-cardLink\" href=\"{{ classic_url }}\">\n        <div class=\"pfg-imageFrame\">\n          <img class=\"pfg-image\" loading=\"lazy\"\n               alt=\"Classic Polo Shirt\"\n               src=\"https://uspoloassn.com.au/cdn/shop/files/MUP3312-981-MS_1.JPG?v=1772509555&width=493\">\n        </div>\n        <div class=\"pfg-caption\">CLASSIC POLO SHIRT</div>\n      </a>\n\n      <!-- 2 -->\n      <a class=\"pfg-cardLink\" href=\"{{ performance_url }}\">\n        <div class=\"pfg-imageFrame\">\n          <img class=\"pfg-image\" loading=\"lazy\"\n               alt=\"Performance Polo Shirt\"\n               src=\"https://uspoloassn.com.au/cdn/shop/files/MUP3313-P90-MS_1.JPG?v=1772509688&width=493\">\n        </div>\n        <div class=\"pfg-caption\">PERFORMANCE POLO SHIRT</div>\n      </a>\n\n      <!-- 3 -->\n      <a class=\"pfg-cardLink\" href=\"{{ premium_url }}\">\n        <div class=\"pfg-imageFrame\">\n          <img class=\"pfg-image\" loading=\"lazy\"\n               alt=\"Premium Polo Shirt\"\n               src=\"https://uspoloassn.com.au/cdn/shop/files/MUP3323-Q50-MS_1.jpg?v=1772509704&width=493\">\n        </div>\n        <div class=\"pfg-caption\">PREMIUM POLO SHIRT</div>\n      </a>\n\n      <!-- 4 -->\n      <a class=\"pfg-cardLink\" href=\"{{ longsleeve_url }}\">\n        <div class=\"pfg-imageFrame\">\n          <img class=\"pfg-image\" loading=\"lazy\"\n               alt=\"Long-Sleeved Polo Shirt\"\n               src=\"https://uspoloassn.com.au/cdn/shop/files/MUP3988-M83-MS_1.JPG?v=1740583943&width=493\">\n        </div>\n        <div class=\"pfg-caption\">LONG-SLEEVED POLO SHIRT</div>\n      </a>\n\n    </div>\n  </div>\n</div>\n\n<style>\n\n.uspa-polo-icon{\n  text-align:center;\n  padding:34px 0 10px;\n}\n\n.uspa-polo-icon img{\n  width:100%;\n  max-width:560px;\n  height:auto;\n  margin:0 auto;\n  display:block;\n}\n\n@media (max-width:749px){\n  .uspa-polo-icon img{\n    max-width:300px;\n  }\n}\n\n.pfg-wrap{\n  padding:20px;\n}\n\n.pfg-inner{\n  max-width:1240px;\n  margin:0 auto;\n  text-align:center;\n}\n\n.pfg-heading{\n  margin:22px 0 14px;\n  font-size:36px;\n  font-weight:400;\n  letter-spacing:1px;\n  text-transform:uppercase;\n  line-height:1.2;\